# YouTube
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_NAME=Nama Channel Kamu
YOUTUBE_BROADCAST_ID=

# Anthropic AI
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Stream Settings
VIDEO_RESOLUTION=1280x720
VIDEO_FPS=30
VIDEO_BITRATE=2500k
AUDIO_BITRATE=128k
RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# Content Settings
# AUTO = ikuti jadwal; atau paksa salah satu kategori berikut:
# MOTIVATIONAL_QUOTES, LOFI_FACTS, STUDY_WITH_ME, TRIVIA_QNA, MEDITATION_GUIDE
CONTENT_CATEGORY=AUTO
CONTENT_INTERVAL_SECONDS=300
CONTENT_LANGUAGE=id
CONTENT_QUEUE_SIZE=10

# Audio Settings
# Suara TTS yang umum: id-ID-ArdiNeural (pria), id-ID-GadisNeural (wanita)
TTS_VOICE=id-ID-ArdiNeural
TTS_PROVIDER=edge-tts
MUSIC_VOLUME=0.2
TTS_VOLUME=0.8

# Background Type: video | slideshow | gradient
BACKGROUND_TYPE=gradient
BACKGROUND_VIDEO_PATH=
SLIDESHOW_TRANSITION_SECONDS=2

# Overlay
OVERLAY_FONT=
SHOW_LIVE_INDICATOR=true
SHOW_SUBSCRIBER_COUNTER=false
SHOW_PROGRESS_BAR=true

# Telegram Notification (opsional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Health Monitor
HEALTH_CHECK_INTERVAL_SECONDS=60
CPU_ALERT_THRESHOLD=85
RAM_ALERT_THRESHOLD=80
LOG_ROTATE_SIZE_MB=100

# Reconnect / Watchdog
MAX_RECONNECT_ATTEMPTS=10
WATCHDOG_RESTART_DELAY_SECONDS=30

# Timezone
TIMEZONE=Asia/Jakarta

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/stream.log
